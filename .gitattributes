# Auto detect text files and perform LF normalization
* text=auto eol=lf

# PHP files always LF
*.php text eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.neon text eol=lf
*.md text eol=lf
*.conf text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
